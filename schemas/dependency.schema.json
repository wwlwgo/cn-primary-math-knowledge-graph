{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cn-primary-math-kg.org/schemas/dependency.schema.json",
  "title": "Knowledge Topic Dependency",
  "type": "object",
  "additionalProperties": false,
  "required": ["topicId", "prerequisiteId", "strength", "reason", "sources", "reviewStatus"],
  "properties": {
    "topicId": {"type": "string", "pattern": "^cn_math_g[1-6]_[a-z][a-z0-9_]{2,80}$"},
    "prerequisiteId": {"type": "string", "pattern": "^cn_math_g[1-6]_[a-z][a-z0-9_]{2,80}$"},
    "strength": {"enum": ["hard", "soft"]},
    "reason": {"type": "string", "minLength": 12, "maxLength": 300},
    "sources": {"type": "array", "minItems": 1, "items": {"$ref": "source.schema.json"}},
    "reviewStatus": {"enum": ["draft", "reviewed", "approved"]}
  }
}
