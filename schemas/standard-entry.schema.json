{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cn-primary-math-kg.org/schemas/standard-entry.schema.json",
  "title": "Curriculum Standard Registry Entry",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "title", "authority", "documentNumber", "issuedAt", "sourceUrl", "sourceLocator", "status"],
  "properties": {
    "id": {"type": "string", "pattern": "^cn-math-2022:[a-z0-9._/-]+$"},
    "title": {"type": "string", "minLength": 5},
    "authority": {"const": "教育部"},
    "documentNumber": {"type": "string", "minLength": 5},
    "issuedAt": {"type": "string", "pattern": "^2022-03-25$"},
    "effectiveFrom": {"type": "string"},
    "sourceUrl": {"type": "string", "format": "uri"},
    "sourceLocator": {"type": "string", "minLength": 3},
    "status": {"enum": ["authoritative-document", "indexed-section"]}
  }
}
