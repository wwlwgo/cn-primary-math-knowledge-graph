{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cn-primary-math-kg.org/schemas/topic.schema.json",
  "title": "China Primary Mathematics Knowledge Topic",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "type", "subject", "domain", "name", "description", "gradeBands", "evidence", "assessmentPrompt", "standards", "capabilityAnchor", "modelLayer", "sources", "reviewStatus"],
  "properties": {
    "id": {"type": "string", "pattern": "^cn_math_g[1-6]_[a-z][a-z0-9_]{2,80}$"},
    "type": {"enum": ["CONCEPTUAL", "PROCEDURAL", "REPRESENTATIONAL", "LANGUAGE", "STRATEGIC", "META"]},
    "subject": {"const": "数学"},
    "domain": {"enum": ["数与代数", "图形与几何", "统计与概率", "综合与实践"]},
    "name": {"type": "string", "minLength": 2, "maxLength": 80},
    "description": {"type": "string", "minLength": 10, "maxLength": 300},
    "gradeBands": {"type": "array", "minItems": 1, "items": {"enum": ["G1", "G2", "G3", "G4", "G5", "G6"]}, "uniqueItems": true},
    "evidence": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 8, "maxLength": 240}},
    "assessmentPrompt": {"type": "string", "minLength": 10, "maxLength": 400},
    "standards": {"type": "array", "minItems": 1, "items": {"type": "string", "pattern": "^cn-math-2022:"}, "uniqueItems": true},
    "capabilityAnchor": {"type": "string", "pattern": "^cn_math_anchor_[a-z0-9_]{3,120}$"},
    "modelLayer": {"enum": ["diagnostic", "implementation_evidence"]},
    "sources": {"type": "array", "minItems": 1, "items": {"$ref": "source.schema.json"}},
    "reviewStatus": {"enum": ["draft", "reviewed", "approved"]}
  }
}
